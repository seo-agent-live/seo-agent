{
  "name": "seo-agent",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');try{fs.rmSync('.next',{recursive:true,force:true});console.log('Removed .next');}catch(e){if(e.code!=='ENOENT')throw e;}\"",
    "dev": "next dev",
    "dev:fresh": "npm run clean && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.0",
    "autoprefixer": "^10.5.0",
    "lucide-react": "^1.14.0",
    "next": "^15.3.2",
    "postcss": "^8.5.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.1.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "typescript": "6.0.3"
  }
}
